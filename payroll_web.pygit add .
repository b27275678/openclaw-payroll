async function uploadSchedule() {
  const file = document.getElementById('scheduleFile').files[0];
  if (!file) { alert('Please choose a file first'); return; }
  const formData = new FormData();
  formData.append('file', file);
  const res = await fetch('/parse_schedule', {method:'POST', body: formData});
  const data = await res.json();
  if (data.error) { document.getElementById('uploadResult').innerHTML = '<p style="color:red">'+data.error+'</p>'; return; }
  importedHours = data;
  let html = '<div style="background:#0f3460;padding:15px;border-radius:8px;margin-top:15px"><p style="color:#f5e642;font-weight:bold;margin-bottom:10px">Hours imported successfully!</p><table style="width:100%">';
  for (const [name, hours] of Object.entries(data)) {
    html += `<tr><td style="padding:4px">${name}</td><td style="color:#f5e642;font-weight:bold">${hours} hrs</td></tr>`;
  }
  html += '</table><br><button class="btn btn-green" onclick="loadImportedEmployees()">Load Employees into Payroll</button></div>';
  document.getElementById('uploadResult').innerHTML = html;
}

